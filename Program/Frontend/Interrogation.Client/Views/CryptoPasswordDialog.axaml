<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Interrogation.Client.Views.CryptoPasswordDialog"
        Width="430" Height="360" CanResize="False"
        WindowStartupLocation="CenterOwner" Title="Криптографическая операция">
  <Grid RowDefinitions="Auto,*" Background="#EFF3F7">
    <Border Background="#1F2933" Padding="24,20">
      <StackPanel Spacing="5">
        <TextBlock x:Name="TitleText" Foreground="White" FontSize="19" FontWeight="SemiBold" />
        <TextBlock Text="AES-256-CBC · OpenSSL · PBKDF2-SHA256" Foreground="#C9D4E2" FontSize="12" />
      </StackPanel>
    </Border>
    <StackPanel Grid.Row="1" Margin="28" Spacing="11">
      <TextBlock Text="Пароль" Foreground="#475467" FontSize="12" />
      <TextBox x:Name="PasswordBox" PasswordChar="●" PlaceholderText="Не менее 10 символов" MinHeight="42" />
      <StackPanel x:Name="ConfirmPanel" Spacing="7">
        <TextBlock Text="Повторите пароль" Foreground="#475467" FontSize="12" />
        <TextBox x:Name="ConfirmPasswordBox" PasswordChar="●" PlaceholderText="Повтор пароля" MinHeight="42" />
      </StackPanel>
      <TextBlock x:Name="ErrorText" Foreground="#9E2A2B" FontSize="12" IsVisible="False" TextWrapping="Wrap" />
      <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
        <Button Content="Отмена" Click="CancelButton_OnClick" HorizontalAlignment="Stretch" />
        <Button Grid.Column="1" Content="Продолжить" Click="ConfirmButton_OnClick" Background="#244C73" Foreground="White" HorizontalAlignment="Stretch" />
      </Grid>
    </StackPanel>
  </Grid>
</Window>
